local taskType = "pt"
while true do
     print("Current Task" .. taskType)
     for i = 0 , 10, 1 do
          print("i: ".. i)
     end
     print("changing Task: " .. taskType)
     taskType = "ht"
     print("Current Task \n" .. taskType)
     for i = 0 , 10, 1 do
          print("i: ".. i)
     end
     print("changing Task: " .. taskType)
     taskType = "uws"
     break
end

